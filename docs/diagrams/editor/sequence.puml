@startuml
!theme plain
title Edit Feature - Sequence Diagram

actor User
participant ":JobPilot" as Main
participant ":Parser" as Parser
participant ":EditorParser" as EditorParser
participant ":CommandRunner" as Runner
participant ":Editor" as Editor
participant "applications\n:ArrayList<Application>" as List
participant ":Ui" as Ui

User -> Main : edit 1 c/Microsoft p/Senior Engineer
activate Main

Main -> Parser : parse(input)
activate Parser

Parser -> EditorParser : parse(input)
activate EditorParser

EditorParser -> EditorParser : normalizeWhitespace()
EditorParser -> EditorParser : extractIndex()
EditorParser -> EditorParser : findFieldsStart()
EditorParser -> EditorParser : parseFields()

opt c/ field present
    EditorParser -> EditorParser : company = "Microsoft"
end

opt p/ field present
    EditorParser -> EditorParser : position = "Senior Engineer"
end

EditorParser --> Parser : ParsedCommand(EDIT, 0, "Microsoft", "Senior Engineer", null, null)
deactivate EditorParser

Parser --> Main : ParsedCommand
deactivate Parser

Main -> Runner : run(cmd)
activate Runner

Runner -> Editor : editApplication(index, applications, newCompany, newPosition, newDate, newStatus)
activate Editor

Editor -> List : get(index)
activate List
List --> Editor : target
deactivate List

opt newCompany != null
    Editor -> Editor : target.setCompany(newCompany)
end

opt newPosition != null
    Editor -> Editor : target.setPosition(newPosition)
end

Editor -> Editor : validateIndex()

Editor -> Ui : showApplicationEdited(target)
activate Ui
Ui --> Editor :
deactivate Ui

Editor --> Runner :
deactivate Editor

Runner --> Main :
deactivate Runner

Main --> User : "Updated application:\nMicrosoft | Senior Engineer | 2024-09-12 | Pending"
deactivate Main

@enduml