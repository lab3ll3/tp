    object "<u>app2:Application</u>" as app2 {
        company = "Amazon"
        position = "Data Analyst"
        date = "01/01/2026"
        status = "PENDING"
        tags = "TECH"
    }

    apps --> app1 : index 0
    apps --> app2 : index 1
}
@enduml
