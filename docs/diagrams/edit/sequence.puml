@startuml
actor User
participant ":JobPilot" as JobPilot
participant ":Edit" as Edit
participant "applications\n:ArrayList<Add>" as List
participant ":Add" as Add

User -> JobPilot : edit 1 c/Google p/SWE d/2024-09-12
activate JobPilot

JobPilot -> Edit : editApplication(input, applications)
activate Edit

Edit -> Edit : parseIndex()
note right: index "1" → 0

Edit -> List : get(0)
activate List
List --> Edit : target application
deactivate List

Edit -> Edit : parseFields()
note right: c/, p/, d/ detected

Edit -> Add : setCompany("Google")
activate Add
Add --> Edit :
deactivate Add

Edit -> Add : setPosition("SWE")
activate Add
Add --> Edit :
deactivate Add

Edit -> Edit : validateDate("2024-09-12")
note right: valid

Edit -> Add : setDate("2024-09-12")
activate Add
Add --> Edit :
deactivate Add

Edit --> JobPilot : success
deactivate Edit

JobPilot --> User : "Updated: Google | SWE | 2024-09-12 | Pending"
deactivate JobPilot
@enduml