@startuml
actor User
participant Ui
participant Parser
participant SearcherParser
participant CommandRunner
participant Application
User -> Ui : "search p/nonexistent"
Ui -> Parser : parse("search p/nonexistent")
Parser -> SearcherParser : parse("search p/nonexistent")
SearcherParser --> Parser : ParsedCommand(type=SEARCH, type="p", query="nonexistent")
Parser --> CommandRunner : run(cmd)
loop for each application
    CommandRunner -> Application : getPosition()
    Application --> CommandRunner : position
    CommandRunner -> CommandRunner : contains(query)?
end
alt no matches found
    CommandRunner -> Ui : showSearchResults(empty, "p/nonexistent")
    Ui --> User : "No applications found matching 'p/nonexistent'."
else matches found
    CommandRunner -> Ui : showSearchResults(results, "p/nonexistent")
    Ui --> User : display results
end
@enduml