@startuml
actor User
participant Ui
participant Parser
participant SearcherParser
participant CommandRunner
participant Application

User -> Ui : "search c/google"
Ui -> Parser : parse("search c/google")
Parser -> SearcherParser : parse("search c/google")
SearcherParser --> Parser : ParsedCommand(type=SEARCH, type="c", query="google")
Parser --> CommandRunner : run(cmd)
loop for each application
    alt type=c
        CommandRunner -> Application : getCompany()
        Application --> CommandRunner : company
    else type=p
        CommandRunner -> Application : getPosition()
        Application --> CommandRunner : position
    else type=s
        CommandRunner -> Application : getStatus()
        Application --> CommandRunner : status
    end
    CommandRunner -> CommandRunner : contains(query)?
end
CommandRunner -> Ui : showSearchResults(results, "c/google")
Ui --> User : display matching results
@enduml